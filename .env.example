# Server
PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret

# Email credentials
# Supported out of the box: Gmail, Outlook/Hotmail/Live, Yahoo, iCloud, Zoho
# Just set EMAIL_USER to your address — the provider is auto-detected from the domain
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your-app-password

# Gmail     → needs App Password: myaccount.google.com/apppasswords
# Outlook   → use your regular password (or App Password if 2FA is on)
# Yahoo     → needs App Password: account.security.yahoo.com
# iCloud    → needs App Password: appleid.apple.com

# For any other provider, set these custom SMTP settings instead:
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# Pricing (in Rupees)
PC_RATE=50
PS5_RATE=100
